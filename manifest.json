{
  "manifest_version": 3,
  "name": "OnlineJobs.ph Description Helper",
  "version": "1.1.0",
  "description": "Keeps the job description visible when you click Apply and fill the form on OnlineJobs.ph.",
  "icons": {
    "16": "icons/icon-16.svg",
    "48": "icons/icon-48.svg",
    "128": "icons/icon-128.svg"
  },
  "host_permissions": ["https://*.onlinejobs.ph/*", "http://*.onlinejobs.ph/*"],
  "content_scripts": [
    {
      "matches": ["https://*.onlinejobs.ph/*", "http://*.onlinejobs.ph/*"],
      "js": ["src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle"
    }
  ]
}
